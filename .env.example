# ================================================================================
# TODOCAMISETAS API - Archivo de Configuración de Entorno
# ================================================================================
# 
# Copia este archivo como ".env" en la raíz del proyecto
# y actualiza los valores según tu entorno
#
# IMPORTANTE: El archivo ".env" contiene contraseñas, NO debe subirse a Git
#
# ================================================================================
# BASE DE DATOS
# ================================================================================

# Host de la base de datos
# En Docker: usa el nombre del servicio "mysql"
# En local: usa "localhost" o "127.0.0.1"
DB_HOST=mysql

# Usuario de MySQL
DB_USER=root

# Contraseña de MySQL
DB_PASSWORD=rootpass

# Nombre de la base de datos
DB_NAME=todo_camisetas

# Puerto de MySQL (solo para conexión local)
MYSQL_PORT=3306

# Contraseña del usuario root en MySQL (para docker-compose)
MYSQL_ROOT_PASSWORD=rootpass

# ================================================================================
# SERVIDOR WEB
# ================================================================================

# Puerto donde está expuesto Nginx localmente
APP_PORT=8080

# Host del servidor web
APP_HOST=0.0.0.0

# ================================================================================
# ZONA HORARIA
# ================================================================================

# Timezone para timestamps
TIMEZONE=America/Santiago

# ================================================================================
# NOTAS IMPORTANTES
# ================================================================================

# 1. Este archivo se llama ".env.example"
#    Copia como ".env" en la raíz del proyecto
#
# 2. Los valores por defecto funcionan con Docker Compose
#
# 3. Si usas la aplicación en local (sin Docker):
#    - Cambiar DB_HOST a "localhost"
#    - Cambiar APP_PORT al puerto de tu servidor PHP
#
# 4. NUNCA subir ".env" a Git - solo ".env.example"
#
# 5. Para cambiar contraseñas:
#    - Actualizar aquí en .env
#    - Ejecutar: docker compose down -v
#    - Ejecutar: docker compose up -d
#
# ================================================================================
